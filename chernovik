function searchSystl(text, count)
    local ans = {}
    for i = #SAtest, 1, -1 do
        local answer = SAtest[i].text
        if string.find(answer, text) then
            table.insert(ans, answer)
            if count and #ans >= count then break end
        end
    end
    return ans
end


